OPENAI_API_KEY=
OPENAI_BRAIN_MODEL=gpt-5.6
OPENAI_BRAIN_TIMEOUT_MS=300000
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
LIVE_AI_ENABLED=false
# Server-only Brain adapter controls. The safe/default Live adapter is one_shot.
# codex_sdk_persistent is a local hackathon exception and also requires
# BRAIN_EXPERIMENTAL_HARNESSES_ENABLED=true.
OPENAI_BRAIN_HARNESS=one_shot
BRAIN_EXPERIMENTAL_HARNESSES_ENABLED=false
BRAIN_PUBLIC_SEARCH_ENABLED=false
# Local hackathon Codex adapter settings. These are unused by one_shot.
OPENAI_CODEX_BRAIN_MODEL=gpt-5.6-sol
CODEX_BRAIN_HOME=.spec-grill-codex
# Server-only, content-free tracing for Responses create/retrieve/cancel plus local validate.
# Never expose this as NEXT_PUBLIC_; leave false except during controlled troubleshooting.
BRAIN_DEBUG_LOGS=false
ALLOWED_ORIGIN=http://localhost:3000
